<UserControl x:Class="DeskCloudCompare.Views.PresetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:DeskCloudCompare.Helpers">

    <UserControl.Resources>
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Preset List -->
        <GroupBox Grid.Column="0" Header="Presets">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Presets}"
                         SelectedItem="{Binding SelectedPreset}"
                         DisplayMemberPath="Name" />

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="Add" Width="60" Margin="0,0,4,0"
                            Command="{Binding AddPresetCommand}" />
                    <Button Content="Delete" Width="60" Margin="0,0,4,0"
                            Command="{Binding DeletePresetCommand}" />
                    <Button Content="Save" Width="60"
                            Command="{Binding SavePresetCommand}" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <GridSplitter Grid.Column="1" VerticalAlignment="Stretch" Width="5" />

        <!-- Right panel: Slots (top) + Exclusions (bottom) -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Preset Slots -->
            <GroupBox Grid.Row="0" Header="Preset Slots">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ItemsControl Grid.Row="0" ItemsSource="{Binding Slots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <GroupBox Header="{Binding SlotLabel, StringFormat='Slot {0}'}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Row="0" Grid.Column="0"
                                                 Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="True" Margin="0,0,4,4"
                                                 Background="#F8F8F8" />
                                        <Button Grid.Row="0" Grid.Column="1"
                                                Content="Browse..."
                                                Command="{Binding BrowseCommand}" />

                                        <ComboBox Grid.Row="1" Grid.ColumnSpan="2"
                                                  ItemsSource="{Binding FolderTypeOptions}"
                                                  SelectedItem="{Binding SelectedFolderType}"
                                                  DisplayMemberPath="Name" />
                                    </Grid>
                                </GroupBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Grid.Row="1" Content="Load into Comparison"
                            Command="{Binding DataContext.LoadIntoComparisonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            HorizontalAlignment="Left" Padding="12,4" Margin="0,8,0,0"
                            Background="#0078D4" Foreground="White" />
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Height="5" />

            <!-- Preset Exclusions -->
            <GroupBox Grid.Row="2" Header="Path Exclusions (applied to canonical path)">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                        <Button Content="Add" Width="70" Margin="0,0,4,0"
                                Command="{Binding AddExclusionCommand}" />
                        <Button Content="Delete" Width="70" Margin="0,0,4,0"
                                Command="{Binding DeleteExclusionCommand}" />
                        <Button Content="Save" Width="70"
                                Command="{Binding SaveExclusionsCommand}" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Exclusions}"
                              SelectedItem="{Binding SelectedExclusion}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              AlternatingRowBackground="#F5F5F5"
                              GridLinesVisibility="All">
                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header="Match Type" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MatchType}" Margin="4,0" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding Data.MatchTypeOptions, Source={StaticResource Proxy}}"
                                                  SelectedItem="{Binding MatchType, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Pattern" Width="*"
                                                Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}" />

                            <DataGridTextColumn Header="Description" Width="*"
                                                Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />

                            <DataGridCheckBoxColumn Header="Active" Width="60"
                                                    Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
