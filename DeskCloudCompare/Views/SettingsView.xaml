<UserControl x:Class="DeskCloudCompare.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:DeskCloudCompare.Helpers">

    <UserControl.Resources>
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Folder Types -->
        <GroupBox Grid.Row="0" Header="Folder Types">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                    <Button Content="Add" Width="70" Margin="0,0,4,0"
                            Command="{Binding AddFolderTypeCommand}" />
                    <Button Content="Delete" Width="70" Margin="0,0,4,0"
                            Command="{Binding DeleteFolderTypeCommand}" />
                    <Button Content="Save" Width="70"
                            Command="{Binding SaveFolderTypesCommand}" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FolderTypes}"
                          SelectedItem="{Binding SelectedFolderType}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          AlternatingRowBackground="#F5F5F5"
                          GridLinesVisibility="All">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Width="*"
                                            Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Height="5" />

        <!-- Path Translation Rules -->
        <GroupBox Grid.Row="2" Header="Path Translation Rules">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                    <Button Content="Add" Width="70" Margin="0,0,4,0"
                            Command="{Binding AddRuleCommand}" />
                    <Button Content="Delete" Width="70" Margin="0,0,4,0"
                            Command="{Binding DeleteRuleCommand}" />
                    <Button Content="Save" Width="70"
                            Command="{Binding SaveRulesCommand}" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding TranslationRules}"
                          SelectedItem="{Binding SelectedRule}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          AlternatingRowBackground="#F5F5F5"
                          GridLinesVisibility="All">
                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="From Type" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FromType.Name}" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding Data.FolderTypeOptions, Source={StaticResource Proxy}}"
                                              SelectedItem="{Binding FromType, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="To Type" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ToType.Name}" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding Data.FolderTypeOptions, Source={StaticResource Proxy}}"
                                              SelectedItem="{Binding ToType, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Find Text" Width="*"
                                            Binding="{Binding FindText, UpdateSourceTrigger=PropertyChanged}" />

                        <DataGridTextColumn Header="Replace Text" Width="*"
                                            Binding="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}" />

                        <DataGridTextColumn Header="Order" Width="60"
                                            Binding="{Binding SortOrder, UpdateSourceTrigger=PropertyChanged}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch" Height="5" />

        <!-- Special File Rules -->
        <GroupBox Grid.Row="4" Header="Special File Rules">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                    <Button Content="Add" Width="70" Margin="0,0,4,0"
                            Command="{Binding AddSpecialRuleCommand}" />
                    <Button Content="Delete" Width="70" Margin="0,0,4,0"
                            Command="{Binding DeleteSpecialRuleCommand}" />
                    <Button Content="Save" Width="70"
                            Command="{Binding SaveSpecialRulesCommand}" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SpecialFileRules}"
                          SelectedItem="{Binding SelectedSpecialRule}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          AlternatingRowBackground="#F5F5F5"
                          GridLinesVisibility="All">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Description" Width="*"
                                            Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />

                        <DataGridTextColumn Header="File Name Pattern" Width="*"
                                            Binding="{Binding FileNamePattern, UpdateSourceTrigger=PropertyChanged}" />

                        <DataGridTemplateColumn Header="Rule Type" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RuleType}" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding Data.RuleTypeOptions, Source={StaticResource Proxy}}"
                                              SelectedItem="{Binding RuleType, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridCheckBoxColumn Header="Active" Width="60"
                                               Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" />

                        <DataGridTextColumn Header="Notes" Width="*"
                                            Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
