<UserControl x:Class="DeskCloudCompare.Views.ComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:DeskCloudCompare.Helpers">

    <UserControl.Resources>
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}" />

        <Style x:Key="ResultCellStyle" TargetType="TextBlock">
            <Style.Triggers>
                <Trigger Property="Text" Value="All identical">
                    <Setter Property="Background" Value="#C8E6C9" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Slot Configuration -->
        <GroupBox Grid.Row="0" Header="Folder Slots" Margin="0,0,0,8">
            <UniformGrid Columns="4" Margin="4">
                <ItemsControl ItemsSource="{Binding Slots}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <GroupBox Header="{Binding SlotLabel, StringFormat='Slot {0}'}" Margin="4">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="70" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="True" Background="#F8F8F8"
                                                 Margin="0,0,4,4" />
                                        <Button Grid.Column="1" Content="Browse..."
                                                Command="{Binding BrowseCommand}" />
                                    </Grid>
                                    <ComboBox ItemsSource="{Binding FolderTypeOptions}"
                                              SelectedItem="{Binding SelectedFolderType}"
                                              DisplayMemberPath="Name" />
                                </StackPanel>
                            </GroupBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </UniformGrid>
        </GroupBox>

        <!-- Action Bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Scan Folders" Padding="12,4" Margin="0,0,6,0"
                    Background="#0078D4" Foreground="White"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding IsNotBusy}" />
            <Button Content="Cancel" Padding="8,4" Margin="0,0,16,0"
                    Command="{Binding CancelCommand}"
                    IsEnabled="{Binding IsBusy}" />
            <Separator Width="1" Margin="0,0,16,0" />
            <Button Content="Select Files Needing Compare" Padding="8,4" Margin="0,0,6,0"
                    Command="{Binding SelectAllForBinaryCompareCommand}"
                    IsEnabled="{Binding IsNotBusy}" />
            <Button Content="Run Binary Compare" Padding="8,4"
                    Background="#E65100" Foreground="White"
                    Command="{Binding BinaryCompareCommand}"
                    IsEnabled="{Binding IsNotBusy}" />
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                       Margin="16,0,0,0" Foreground="#555" />
        </StackPanel>

        <!-- Results Grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5"
                  GridLinesVisibility="All"
                  SelectionMode="Extended">
            <DataGrid.Columns>

                <DataGridCheckBoxColumn Header="&#x2713;" Width="30"
                                        Binding="{Binding IsSelectedForBinaryCompare, UpdateSourceTrigger=PropertyChanged}"
                                        IsReadOnly="False" />

                <DataGridTextColumn Header="Canonical Path" Width="250"
                                    Binding="{Binding CanonicalPath}" />
                <DataGridTextColumn Header="File Name" Width="180"
                                    Binding="{Binding FileName}" />

                <DataGridTextColumn Header="Path A" Width="160" Binding="{Binding PathA}" />
                <DataGridTextColumn Header="Path B" Width="160" Binding="{Binding PathB}" />
                <DataGridTextColumn Header="Path C" Width="160" Binding="{Binding PathC}" />
                <DataGridTextColumn Header="Path D" Width="160" Binding="{Binding PathD}" />

                <DataGridTextColumn Header="Size A" Width="80"
                                    Binding="{Binding SizeA, StringFormat=N0}"
                                    ElementStyle="{StaticResource {x:Type TextBlock}}" />
                <DataGridTextColumn Header="Size B" Width="80"
                                    Binding="{Binding SizeB, StringFormat=N0}" />
                <DataGridTextColumn Header="Size C" Width="80"
                                    Binding="{Binding SizeC, StringFormat=N0}" />
                <DataGridTextColumn Header="Size D" Width="80"
                                    Binding="{Binding SizeD, StringFormat=N0}" />

                <DataGridTextColumn Header="Date A" Width="135"
                                    Binding="{Binding DateA, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                <DataGridTextColumn Header="Date B" Width="135"
                                    Binding="{Binding DateB, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                <DataGridTextColumn Header="Date C" Width="135"
                                    Binding="{Binding DateC, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                <DataGridTextColumn Header="Date D" Width="135"
                                    Binding="{Binding DateD, StringFormat='yyyy-MM-dd HH:mm:ss'}" />

                <DataGridTemplateColumn Header="Result" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Result}" Margin="4,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Result}" Value="All identical">
                                                <Setter Property="Background" Value="#C8E6C9" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NeedsCompare}" Value="True">
                                                <Setter Property="Foreground" Value="#B71C1C" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Binary Result" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding BinaryResult}" Margin="4,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BinaryResult}" Value="Identical">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding BinaryResult}" Value="Different">
                                                <Setter Property="Foreground" Value="#B71C1C" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="3" Height="4" Margin="0,4,0,0"
                     IsIndeterminate="{Binding IsBusy}"
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
    </Grid>
</UserControl>
