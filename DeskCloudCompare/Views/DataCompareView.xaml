<UserControl x:Class="DeskCloudCompare.Views.DataCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
            <TextBlock Text="Data Compare" FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,16" />
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" Foreground="#555" FontSize="13">
                This tab will enable comparison of data between .dxdb files and their corresponding .csv exports.
                <LineBreak /><LineBreak />
                Decryption support for .dxdb files is required before this feature can be implemented.
                Once available, field-level mappings (configured in Settings) will drive automatic matching
                between the two data sources.
                <LineBreak /><LineBreak />
                The schema tables (DxdbCsvMapping, FieldMapping) are already in place and ready.
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
